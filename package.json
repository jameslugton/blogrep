{
  "name": "blogrep",
  "version": "1.0.0",
  "description": "EmDash - A modern blog hosted on Cloudflare",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next export",
    "start": "next start",
    "lint": "next lint",
    "import:wp": "node scripts/import-wordpress.mjs",
    "import:wp:xml": "node scripts/import-wordpress-xml.mjs",
    "deploy:pages": "wrangler pages deploy out",
    "deploy:cloudflare": "npm run build && wrangler pages deploy out --project-name blogrep"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "next": "^14.2.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.3",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.18",
    "fast-xml-parser": "^4.5.0",
    "@types/react": "^18.3.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.80.0"
  }
}
